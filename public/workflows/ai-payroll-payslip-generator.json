            {
              "parameters": {
                "jsCode": "const baseSalary = $input.item.json.body.baseSalary || 0;\nconst unpaidLeaves = $('Fetch Employee Data').item.json.unpaidLeaves || 0;\nconst taxRate = 0.1; // 10% tax\n\nconst dailyRate = baseSalary / 30;\nconst grossPay = baseSalary;\nconst leaveDeduction = dailyRate * unpaidLeaves;\nconst taxableAmount = grossPay - leaveDeduction;\nconst taxDeduction = taxableAmount * taxRate;\nconst netPayable = taxableAmount - taxDeduction;\n\nreturn [{\n  json: {\n    employeeId: $input.item.json.body.employeeId,\n    employeeName: $('Fetch Employee Data').item.json.fields.Name || 'Employee',\n    month: $input.item.json.body.month,\n    baseSalary: baseSalary,\n    unpaidLeaves: unpaidLeaves,\n    grossPay: Math.round(grossPay * 100) / 100,\n    leaveDeduction: Math.round(leaveDeduction * 100) / 100,\n    taxDeduction: Math.round(taxDeduction * 100) / 100,\n    totalDeductions: Math.round((leaveDeduction + taxDeduction) * 100) / 100,\n    netPayable: Math.round(netPayable * 100) / 100\n  }\n}];"
              },
              "id": "3da5adfa-a58f-4b67-8f03-bc148e451a69",
              "name": "Salary Calculation Engine",
              "type": "n8n-nodes-base.code",
