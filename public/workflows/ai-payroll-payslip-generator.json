              ],
              "credentials": {
                "openAiApi": {
                  "id": "R7nqRWbajKv4DK31",
                  "name": "OpenAi account"
                }
              }
            },
            {
              "parameters": {
                "jsCode": "const salaryData = $('Salary Calculation Engine').item.json;\nconst aiRemarks = $json.message || '';\n\nconst html = `\n<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: Arial, sans-serif; margin: 40px; }\n    .header { text-align: center; margin-bottom: 30px; }\n    .company { font-size: 24px; font-weight: bold; color: #333; }\n    .payslip-title { font-size: 18px; color: #666; margin-top: 10px; }\n    .employee-info { margin: 20px 0; }\n    .info-row { display: flex; margin: 8px 0; }\n    .label { font-weight: bold; width: 200px; }\n    .value { color: #555; }\n    table { width: 100%; border-collapse: collapse; margin: 20px 0; }\n    th, td { padding: 12px; text-align: left; border-bottom: 1px solid #ddd; }\n    th { background-color: #f5f5f5; font-weight: bold; }\n    .total-row { font-weight: bold; font-size: 16px; background-color: #f0f0f0; }\n    .remarks { margin-top: 30px; padding: 15px; background-color: #f9f9f9; border-left: 4px solid #4CAF50; }\n    .footer { margin-top: 40px; text-align: center; color: #888; font-size: 12px; }\n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <div class=\"company\">Company Name</div>\n    <div class=\"payslip-title\">PAYSLIP - ${salaryData.month}</div>\n  </div>\n  \n  <div class=\"employee-info\">\n    <div class=\"info-row\">\n      <span class=\"label\">Employee ID:</span>\n      <span class=\"value\">${salaryData.employeeId}</span>\n    </div>\n    <div class=\"info-row\">\n      <span class=\"label\">Employee Name:</span>\n      <span class=\"value\">${salaryData.employeeName}</span>\n    </div>\n    <div class=\"info-row\">\n      <span class=\"label\">Month:</span>\n      <span class=\"value\">${salaryData.month}</span>\n    </div>\n  </div>\n\n  <table>\n    <tr>\n      <th>Description</th>\n      <th style=\"text-align: right;\">Amount</th>\n    </tr>\n    <tr>\n      <td>Base Salary</td>\n      <td style=\"text-align: right;\">₹${salaryData.baseSalary.toFixed(2)}</td>\n    </tr>\n    <tr>\n      <td>Gross Pay</td>\n      <td style=\"text-align: right;\">₹${salaryData.grossPay.toFixed(2)}</td>\n    </tr>\n    <tr>\n      <td>Leave Deduction (${salaryData.unpaidLeaves} days)</td>\n      <td style=\"text-align: right;\">-₹${salaryData.leaveDeduction.toFixed(2)}</td>\n    </tr>\n    <tr>\n      <td>Tax Deduction</td>\n      <td style=\"text-align: right;\">-₹${salaryData.taxDeduction.toFixed(2)}</td>\n    </tr>\n    <tr>\n      <td>Total Deductions</td>\n      <td style=\"text-align: right;\">-₹${salaryData.totalDeductions.toFixed(2)}</td>\n    </tr>\n    <tr class=\"total-row\">\n      <td>Net Payable</td>\n      <td style=\"text-align: right;\">₹${salaryData.netPayable.toFixed(2)}</td>\n    </tr>\n  </table>\n\n  <div class=\"remarks\">\n    <strong>AI Remarks:</strong><br/>\n    ${aiRemarks}\n  </div>\n\n  <div class=\"footer\">\n    This is a computer-generated payslip and does not require a signature.\n  </div>\n</body>\n</html>\n`;\n\nreturn [{\n  json: {\n    ...salaryData,\n    ai_response: aiRemarks,\n    html: html\n  }\n}];"
              },
