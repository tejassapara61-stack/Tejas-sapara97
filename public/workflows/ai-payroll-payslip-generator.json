                },
                "responses": {
                  "values": [
                    {
                      "content": "=You are an HR Payroll Assistant. Based on the calculated Net Salary of {{ $json.netPayable }} and {{ $json.unpaidLeaves }} unpaid leaves, generate a short, professional 2-line remark for the employee's payslip (e.g., 'Salary processed successfully with 2 unpaid leave deductions. Keep up the good work!')."
                    }
                  ]
                },
                "builtInTools": {},
                "options": {}
              },
              "id": "69cafd3b-cd8c-4fdc-b0c9-58582f3474a9",
              "name": "AI Payroll Assistant",
              "type": "@n8n/n8n-nodes-langchain.openAi",
              "typeVersion": 2.1,
              "position": [
                672,
