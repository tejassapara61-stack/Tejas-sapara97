        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  // 1. Safe extraction: Agar body nahi mili toh crash nahi hoga, empty object lega\n  const uiData = item.json.body || item.json || {}; \n  \n  const candidateName = uiData['Candidate Name'] || \"Candidate\";\n  const phoneNumber = uiData['Phone Number'] || \"\";\n  const role = uiData['Job Role'] || \"Developer\";\n  const experience = uiData['Experience'] || \"Fresher\";\n\n  // 2. Safe Phone Formatting\n  let cleanNumber = String(phoneNumber).replace(/\\D/g, '');\n  let standardizedNumber = cleanNumber.length === 10 ? cleanNumber : \n                          (cleanNumber.length === 12 && cleanNumber.startsWith('91') ? cleanNumber.slice(2) : 'incorrect format');\n\n  // 3. JD Summary Auto-Generator\n  let shortJdSummary = `Conduct a technical screening for the ${role} position focusing on core fundamental skills and logic.`;\n  \n  if (role.toLowerCase().includes(\"python\")) {\n      shortJdSummary = \"Focus on Python core concepts, Django framework, REST APIs, and basic SQL queries. Ask practical problem-solving questions.\";\n  } else if (role.toLowerCase().includes(\"professor\") || role.toLowerCase().includes(\"teacher\")) {\n      shortJdSummary = \"Focus on teaching methodologies, subject matter expertise, and classroom management. Do not ask coding questions.\";\n  }\n\n  // 4. Send clean data to Vapi\n  return {\n    json: {\n      'Candidate Name': candidateName,\n      'Job Role': role,\n      'Experience': experience,\n      'Phone Number': standardizedNumber,\n      'jd_summary': shortJdSummary \n    }\n  };\n});"
      },
