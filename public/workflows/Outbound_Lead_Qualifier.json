    {
      "parameters": {
        "jsCode": "// 1. Fetching raw data from Vapi\nconst vapiData = $input.all()[0].json;\n\n// 2. Safely extracting structured outputs (Marks)\nconst marks = vapiData.analysis?.structuredOutputs || {};\n\n// 3. Calculating Scores (1 Right = 20 Marks)\n// Using Number() ensures even if Vapi sends a string \"1\", math works perfectly.\nconst q1 = Number(marks.q1_score || 0) * 20;\nconst q2 = Number(marks.q2_score || 0) * 20;\nconst q3 = Number(marks.q3_score || 0) * 20;\nconst q4 = Number(marks.q4_score || 0) * 20;\nconst q5 = Number(marks.q5_score || 0) * 20;\n\nconst totalScore = q1 + q2 + q3 + q4 + q5;\n\n// 4. The 60+ Pass Logic\nconst finalStatus = totalScore >= 60 ? \"SHORTLISTED ✅\" : \"REJECTED ❌\";\n\n// 5. Extracting Candidate details safely\nconst candidateName = vapiData.assistantOverrides?.variableValues?.candidate_name || \"Unknown Candidate\";\nconst jobRole = vapiData.assistantOverrides?.variableValues?.job_role || \"Unknown Role\";\nconst phone = vapiData.customer?.number || \"N/A\";\nconst summary = vapiData.analysis?.summary || \"No summary available.\";\nconst transcript = vapiData.transcript || \"No transcript available.\";\n\n// 6. Returning an ultra-clean JSON for the next step\nreturn {\n  json: {\n    candidateName,\n    jobRole,\n    phone,\n    totalScore,\n    status: finalStatus,\n    summary,\n    transcript,\n    date: new Date().toLocaleDateString('en-IN')\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        192
      ],
      "id": "e62aef73-35c6-484f-8904-11e185b8dd2b",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const d = $input.all()[0].json;\n\n// Dynamic Styling logic based on Shortlisted/Rejected\nconst isPass = d.status.includes(\"SHORTLISTED\");\nconst badgeColor = isPass ? \"#10B981\" : \"#EF4444\"; // Emerald Green for Pass, Red for Fail\nconst badgeBg = isPass ? \"#D1FAE5\" : \"#FEE2E2\";\n\nconst htmlTemplate = `\n<!DOCTYPE html>\n<html>\n<head>\n    <style>\n        body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #1F2937; line-height: 1.6; padding: 40px; margin: 0; }\n        .header { text-align: center; border-bottom: 2px solid #E5E7EB; padding-bottom: 20px; margin-bottom: 30px; }\n        .logo-text { font-size: 32px; font-weight: 900; color: #4F46E5; margin: 0; }\n        .sub-logo { font-size: 14px; color: #6B7280; text-transform: uppercase; letter-spacing: 2px; }\n        \n        .candidate-info { display: flex; justify-content: space-between; background: #F9FAFB; padding: 20px; border-radius: 8px; margin-bottom: 30px; border: 1px solid #E5E7EB; }\n        .candidate-info p { margin: 5px 0; font-size: 16px; }\n        \n        .score-card { text-align: center; padding: 30px; border-radius: 12px; border: 2px solid ${badgeColor}; background-color: ${badgeBg}; margin-bottom: 30px; }\n        .score-card h1 { font-size: 48px; margin: 0; color: ${badgeColor}; }\n        .score-card h2 { margin: 10px 0 0 0; font-size: 24px; color: #1F2937; }\n        \n        .section-title { color: #4F46E5; border-bottom: 2px solid #4F46E5; padding-bottom: 5px; margin-top: 30px; font-size: 20px; }\n        .summary-text { font-size: 16px; color: #374151; background: #F3F4F6; padding: 15px; border-radius: 8px; border-left: 4px solid #4F46E5; }\n        \n        .transcript-box { background: #111827; color: #D1D5DB; padding: 20px; border-radius: 8px; font-family: monospace; font-size: 12px; white-space: pre-wrap; margin-top: 15px; }\n        \n        .footer { text-align: center; font-size: 12px; color: #9CA3AF; margin-top: 50px; border-top: 1px solid #E5E7EB; padding-top: 20px; }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <h1 class=\"logo-text\">⚡ CoreNexa</h1>\n        <p class=\"sub-logo\">AI Technical Evaluation Report</p>\n    </div>\n    \n    <div class=\"candidate-info\">\n        <div>\n            <p><strong>Candidate:</strong> ${d.candidateName}</p>\n            <p><strong>Role:</strong> ${d.jobRole}</p>\n        </div>\n        <div>\n            <p><strong>Date:</strong> ${d.date}</p>\n            <p><strong>Phone:</strong> ${d.phone}</p>\n        </div>\n    </div>\n    \n    <div class=\"score-card\">\n        <h1>${d.totalScore} / 100</h1>\n        <h2>${d.status}</h2>\n    </div>\n    \n    <h3 class=\"section-title\">AI Interview Summary</h3>\n    <div class=\"summary-text\">\n        ${d.summary}\n    </div>\n    \n    <h3 class=\"section-title\">Full Call Transcript</h3>\n    <div class=\"transcript-box\">${d.transcript}</div>\n    \n    <div class=\"footer\">\n        Confidential Report • Generated automatically by CoreNexa AI Engine\n    </div>\n</body>\n</html>\n`;\n\nreturn { \n  json: { \n    htmlContent: htmlTemplate, \n    fileName: `CoreNexa_Report_${d.candidateName.replace(/\\s+/g, '_')}.pdf`,\n    candidateName: d.candidateName,\n    totalScore: d.totalScore,\n    status: d.status\n  } \n};"
      },
